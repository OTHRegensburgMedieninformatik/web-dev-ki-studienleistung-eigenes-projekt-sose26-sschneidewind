<body>

  {{#if signed_in}}
    {{> menu id="/" name=name surname=surname}}
  {{else}}
    {{> welcomemenu id="home"}}
  {{/if}}

  <main>
    <div class="container-fluid">
      <div class="card mt-3">
        <div class="card-header">
            <h3>{{title}}</h3>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-3">
              <p class="card-text">A Website where YOU can rate your favourite places, connect with others and decide on your upcoming culinary adventures!</p>
            </div>
            <div class="col-9">
              <img src="/images/regensburg_map.png">
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  {{>footer}}

</body>