<body>
    {{> menu id="/" name=name surname=surname}}
    <main>
        <div class="container-fluid">
            <div class="card mt-3">
                <div class="card-header">
                    <h2>Profile of {{name}} {{surname}}</h2>
                </div>
                <div class="card-body">
                    <form action="/change_profile_attributes" method="POST">
                        <div class="mb-3">
                            <label for="inputName" class="form-label">Name</label>
                            <input type="text" class="form-control" id="inputName" name="name" value="{{name}}">
                        </div>
                        <div class="mb-3">
                            <label for="inputSurname" class="form-label">Surname</label>
                            <input type="text" class="form-control" id="inputSurname" name="surname" value="{{surname}}">
                        </div>
                        <div class="mb-3">
                            <label for="inputEmail" class="form-label">Current Email</label>
                            <input type="email" class="form-control" id="inputEmail" name="email" value="{{email}}">
                        </div>
                        <div class="mb-3">
                            <label for="inputNewEmail" class="form-label">New Email (optional)</label>
                            <input type="email" class="form-control" id="inputNewEmail" name="newEmail">
                        </div>
                        <div class="mb-3">
                            <label for="inputStreet" class="form-label">Full Address</label>
                            <input type="text" class="form-control" id="inputStreet" name="street" value="{{street}}">
                        </div>
                        <div class="mb-3">
                            <label for="inputPostalCode" class="form-label">Postal Code</label>
                            <input type="number" class="form-control" id="inputPostalCode" name="postal_code" value="{{postal_code}}">
                        </div>
                        <div class="mb-3">
                            <label for="inputCity" class="form-label">City</label>
                            <input type="text" class="form-control" id="inputCity" name="city" value="{{city}}">
                        </div>
                        <div class="mb-3">
                            <label for="inputCountry" class="form-label">Country</label>
                            <input type="text" class="form-control" id="inputCountry" name="country" value="{{country}}">
                        </div>
                        <div class="mb-5"></div>
                        <div class="mb-3">
                            <label for="inputPassword" class="form-label">Current Password for verification</label>
                            <input type="password" class="form-control" id="inputPassword" name="password">
                        </div>
                        <div class="mb-3">
                            <label for="inputNewPassword" class="form-label">New Password (optional)</label>
                            <input type="password" class="form-control" id="inputNewPassword" name="newPassword">
                        </div>
                        <div>
                            <button type="submit" class="btn btn-primary">Change Information</button>
                            {{#if error}} {{error_msg}} {{/if}}
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
    {{>footer}}
</body>